{
  "name": "astro-paper-v6",
  "type": "module",
  "version": "6.1.0",
  "engines": {
    "node": "^22.22.3 || ^24.16.0 || >=26.3.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && pagefind --site dist && node -e \"require('fs').cpSync('dist/pagefind','public/pagefind',{recursive:true})\"",
    "preview": "astro preview",
    "sync": "astro sync",
    "fetch:rss": "tsx scripts/fetch-rss.ts",
    "check:feeds": "tsx scripts/fetch-rss.ts --dry-run",
    "ingest:news": "tsx scripts/ingest-news.ts",
    "check:news": "tsx scripts/ingest-news.ts --dry-run",
    "enrich:news": "tsx scripts/enrich-news.ts",
    "test": "tsx --test tests/fetch-rss.test.ts tests/news-schema.test.ts tests/news-ingestion.test.ts tests/news-summarizer.test.ts tests/news-enrichment.test.ts",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.3",
    "dayjs": "^1.11.21",
    "lodash.kebabcase": "^4.1.1",
    "rehype-callouts": "^2.2.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.2",
    "slugify": "^1.6.9",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@pagefind/default-ui": "^1.5.2",
    "@shikijs/transformers": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "pagefind": "^1.5.2",
    "prettier": "3.9.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
