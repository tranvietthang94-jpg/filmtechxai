---
import type { HTMLAttributes } from "astro/types";
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const currentYear = new Date().getFullYear();
---

<footer
  class:list={["peek-site-footer", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="peek-site-footer-inner">
    <span class="peek-site-footer-brand">
      © {currentYear}
      {config.site.title}
    </span>
    <nav class="peek-site-footer-nav">
      <a href={getRelativeLocaleUrl(locale, "about")}>Giới thiệu</a>
      <a href={getRelativeLocaleUrl(locale, "posts")}>Bài viết</a>
      <a href={getRelativeLocaleUrl(locale, "tags")}>Tags</a>
      <a href={getRelativeLocaleUrl(locale, "rss.xml")}>RSS</a>
    </nav>
    <span class="peek-site-footer-note">
      Bản tin tổng hợp có ghi nguồn. Bản quyền nội dung gốc thuộc về đơn vị phát
      hành; filmtechXAI chỉ biên tập chỉ mục và điều hướng đọc.
    </span>
  </div>
</footer>
