---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { RSS_SOURCES, YOUTUBE_CHANNELS } from "@/config/sources";
import { getPostUrl } from "@/utils/getPostPaths";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPost = sortedPosts.find(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(post => post !== featuredPost);
const hotPosts = recentPosts.slice(0, 5);
const sourceCount = RSS_SOURCES.length + YOUTUBE_CHANNELS.length;
const sourceLogoUrl = (domain: string) =>
  `https://www.google.com/s2/favicons?domain=${encodeURIComponent(domain)}&sz=64`;
const sourceDomain = (author: string) => {
  const source = RSS_SOURCES.find(item => item.name === author);
  if (!source) return "youtube.com";
  try {
    return new URL(source.url).hostname;
  } catch {
    return source.url;
  }
};
---

<Layout>
  <Header />

  <div class="peek-layout">
    <main id="main-content" class="peek-feed" data-pagefind-body>
      <section class="peek-feed-intro">
        <div>
          <p class="peek-eyebrow"><span></span> CẬP NHẬT LIÊN TỤC</p>
          <h1>Bảng tin AI &amp; Film Tech</h1>
          <p>Tin đáng chú ý về công cụ sáng tạo, quay dựng và công nghệ làm phim — được dẫn về nguồn gốc.</p>
        </div>
        <span class="peek-source-count">{sourceCount} nguồn</span>
      </section>

      {
        featuredPost && (
          <section class="peek-feed-section" aria-labelledby="featured-title">
            <div class="peek-section-heading">
              <h2 id="featured-title">Đáng chú ý</h2>
              <span>01</span>
            </div>
            <ul class="peek-feed-list">
              <Card variant="h3" {...featuredPost} />
            </ul>
          </section>
        )
      }

      <section class="peek-feed-section" aria-labelledby="latest-title">
        <div class="peek-section-heading">
          <h2 id="latest-title">Mới nhất</h2>
          <a href={getRelativeLocaleUrl(locale, "posts")}>Xem tất cả →</a>
        </div>
        {
          recentPosts.length > 0 ? (
            <ul class="peek-feed-list">
              {recentPosts.slice(0, config.posts.perIndex).map(post => <Card variant="h3" {...post} />)}
            </ul>
          ) : (
            <p class="peek-empty-state">Bảng tin đang được cập nhật.</p>
          )
        }
      </section>

      <div class="my-8 text-center">
        <LinkButton href={getRelativeLocaleUrl(locale, "posts")} class="peek-outline-button">
          {t.home.allPosts} →
        </LinkButton>
      </div>
    </main>

    <aside class="peek-rail" aria-label="Tin nổi bật">
      <section class="peek-panel">
        <div class="peek-panel-title">Đang chú ý <span class="peek-panel-live"><span class="peek-live-dot"></span> LIVE</span></div>
        {
          hotPosts.map(post => (
            <a class="peek-prow" href={getPostUrl(post.id, post.filePath, locale)}>
              <img class="peek-prow-logo" src={sourceLogoUrl(sourceDomain(post.data.author))} alt="" loading="lazy" />
              <div>
                <div class="peek-prow-title">{post.data.title}</div>
                <div class="peek-prow-sub">{post.data.author}</div>
              </div>
            </a>
          ))
        }
      </section>
      <section class="peek-panel">
        <div class="peek-panel-title">Nguồn đang theo dõi</div>
        <p class="peek-rail-note">AI, camera, workflow hậu kỳ và thiết bị sáng tạo từ các nguồn quốc tế được chọn lọc.</p>
        <a class="peek-rail-link" href={getRelativeLocaleUrl(locale, "about")}>Xem nguyên tắc biên tập →</a>
      </section>
    </aside>
  </div>

  <Footer />
</Layout>
