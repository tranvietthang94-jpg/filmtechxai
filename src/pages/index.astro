---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { RSS_SOURCES, YOUTUBE_CHANNELS } from "@/config/sources";
import { getPostUrl } from "@/utils/getPostPaths";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
const searchPath = getRelativeLocaleUrl(locale, "search");
const tagAiPath = getRelativeLocaleUrl(locale, "tags/ai");
const tagFilmPath = getRelativeLocaleUrl(locale, "tags/film");
const youtubeSearchPath = `${searchPath}?q=youtube`;

type SourceKind = "ai" | "film" | "youtube" | "site";

type FeedSource = {
  name: string;
  domain: string;
  href: string;
  kind: SourceKind;
};

function getDomain(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url.replace(/^https?:\/\//, "").split("/")[0];
  }
}

function getOrigin(url: string): string {
  try {
    return new URL(url).origin;
  } catch {
    return url;
  }
}

const rssSources: FeedSource[] = RSS_SOURCES.map(source => ({
  name: source.name,
  domain: getDomain(source.url),
  href: getOrigin(source.url),
  kind: source.category,
}));

const youtubeSources: FeedSource[] = YOUTUBE_CHANNELS.map(channel => ({
  name: channel.name,
  domain: "youtube.com",
  href: `https://www.youtube.com/channel/${channel.channelId}`,
  kind: "youtube",
}));

const sources = [...rssSources, ...youtubeSources];
const visibleSources = sources.slice(0, 14);
const hiddenSourceCount = sources.length - visibleSources.length;

const sourceByName = new Map(
  sources.map(source => [source.name.toLowerCase(), source])
);

const fallbackSource: FeedSource = {
  name: config.site.title,
  domain: "warehousevn.cloud",
  href: config.site.url,
  kind: "site",
};

const sourceLogoUrl = (source: FeedSource) =>
  `https://www.google.com/s2/favicons?domain=${encodeURIComponent(
    source.domain
  )}&sz=64`;

const getPostSource = (post: (typeof sortedPosts)[number]) =>
  sourceByName.get(post.data.author.toLowerCase()) ?? fallbackSource;

const sourceCounts = {
  ai: RSS_SOURCES.filter(source => source.category === "ai").length,
  film: RSS_SOURCES.filter(source => source.category === "film").length,
  youtube: YOUTUBE_CHANNELS.length,
};

const dateFormatter = new Intl.DateTimeFormat(locale, {
  dateStyle: "medium",
  timeZone: config.site.timezone,
});
const todayKeyFormatter = new Intl.DateTimeFormat("en-CA", {
  timeZone: config.site.timezone,
});
const todayKey = todayKeyFormatter.format(new Date());
const formatPostDate = (date: Date) => dateFormatter.format(date);
const todayPosts = recentPosts.filter(
  post => todayKeyFormatter.format(post.data.pubDatetime) === todayKey
);
const hotPosts = recentPosts.slice(0, 5);
const railTodayPosts = (todayPosts.length > 0 ? todayPosts : recentPosts).slice(
  0,
  4
);
const heroSources = sources.slice(0, 4);
---

<Layout>
  <Header />

  <div class="peek-layout">
    <aside class="peek-sidebar">
      <nav>
        <a href={homePath} class="peek-nav-item active">
          <span>🏠</span> Trang chủ
        </a>
        <a href={getRelativeLocaleUrl(locale, "posts")} class="peek-nav-item">
          <span>🕒</span>
          {t.nav.posts}
        </a>
        <a href={getRelativeLocaleUrl(locale, "tags")} class="peek-nav-item">
          <span>🏷️</span>
          {t.nav.tags}
        </a>
        <a href={getRelativeLocaleUrl(locale, "about")} class="peek-nav-item">
          <span>ℹ️</span>
          {t.nav.about}
        </a>
      </nav>

      <div class="peek-side-title">
        <span>Lọc bảng tin</span>
      </div>
      <nav>
        <a href={homePath} class="peek-src-item active">
          <span>●</span>
          <span style="flex: 1;">Tất cả nguồn</span>
          <span class="peek-src-badge">{sources.length}</span>
        </a>
        <a href={tagAiPath} class="peek-src-item">
          <span>AI</span>
          <span style="flex: 1;">Trí tuệ nhân tạo</span>
          <span class="peek-src-badge">{sourceCounts.ai}</span>
        </a>
        <a href={tagFilmPath} class="peek-src-item">
          <span>🎬</span>
          <span style="flex: 1;">Film tech</span>
          <span class="peek-src-badge">{sourceCounts.film}</span>
        </a>
        <a href={youtubeSearchPath} class="peek-src-item">
          <span>▶</span>
          <span style="flex: 1;">YouTube</span>
          <span class="peek-src-badge">{sourceCounts.youtube}</span>
        </a>
      </nav>

      <div class="peek-side-title">
        <span>Nguồn đang theo dõi</span>
        <span>{sources.length}</span>
      </div>
      <nav>
        {
          visibleSources.map(source => (
            <a
              class="peek-follow-row"
              href={source.href}
              target="_blank"
              rel="noreferrer"
            >
              <img
                class={`peek-follow-avatar ${
                  source.kind === "youtube"
                    ? "peek-follow-channel"
                    : "peek-follow-logo"
                }`}
                src={sourceLogoUrl(source)}
                alt={source.name}
              />
              {source.kind === "youtube" && (
                <span class="peek-follow-yt">▶</span>
              )}
              {source.name}
            </a>
          ))
        }
        {
          hiddenSourceCount > 0 && (
            <div class="peek-follow-etc">
              …và {hiddenSourceCount} nguồn uy tín khác
            </div>
          )
        }
      </nav>
    </aside>

    <main id="main-content" class="peek-feed">
      <section id="hero" class="peek-hero">
        <span class="peek-hero-flame">🔥</span>
        <div class="peek-hero-meta">
          <span class="peek-src-type">📰</span>
          <span>{config.site.title}</span>
          <span class="dot">·</span>
          <span>AI, film tech và thiết bị sáng tạo</span>
          <span class="peek-hero-hot">Cập nhật mỗi ngày</span>
        </div>
        <h1 class="peek-hero-title">
          {config.site.title} — bản tin nhanh cho người làm nội dung
        </h1>
        <p class="peek-hero-summary">
          Theo dõi các chuyển động mới về AI, camera, hậu kỳ, phần mềm sáng tạo
          và thiết bị làm phim từ những nguồn quốc tế đã chọn lọc.
        </p>
        <div class="peek-hero-foot">
          <span class="peek-hero-sources">
            {
              heroSources.map(source => (
                <img
                  class="peek-savatar peek-savatar-logo"
                  src={sourceLogoUrl(source)}
                  alt={source.name}
                />
              ))
            }
          </span>
          <span class="peek-hero-srctext">
            {sources.length} nguồn đang theo dõi
          </span>
          <a href={getRelativeLocaleUrl(locale, "posts")} class="peek-hero-btn">
            Xem bảng tin →
          </a>
        </div>
      </section>

      {
        featuredPosts.length > 0 && (
          <section id="featured">
            <h2 class="mb-4 flex items-center gap-2 text-xl font-bold">
              <span>⭐</span> {t.home.featured}
            </h2>
            <ul class="flex flex-col gap-4">
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
        )
      }

      {
        recentPosts.length > 0 && (
          <section id="recent-posts">
            <h2 class="mb-4 flex items-center gap-2 text-xl font-bold">
              <span>🕒</span> {t.home.recentPosts}
            </h2>
            <ul class="flex flex-col gap-4">
              {recentPosts.slice(0, postsConfig.perIndex).map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
        )
      }

      <div class="my-8 text-center">
        <LinkButton
          href={getRelativeLocaleUrl(locale, "posts")}
          class="peek-hero-btn inline-block"
        >
          {t.home.allPosts} →
        </LinkButton>
      </div>

      <div class="feed-sentinel"></div>
    </main>

    <aside class="peek-rail">
      <section class="peek-panel">
        <div class="peek-panel-title">
          🔥 Đang chú ý
          <span class="peek-panel-live">
            <span class="peek-live-dot"></span> LIVE
          </span>
        </div>
        {
          hotPosts.map(post => {
            const source = getPostSource(post);
            return (
              <a
                class="peek-prow"
                href={getPostUrl(post.id, post.filePath, locale)}
              >
                <img
                  class="peek-prow-logo"
                  src={sourceLogoUrl(source)}
                  alt={source.name}
                />
                <div>
                  <div class="peek-prow-title">{post.data.title}</div>
                  <div class="peek-prow-sub">
                    {source.name} · {formatPostDate(post.data.pubDatetime)}
                  </div>
                </div>
              </a>
            );
          })
        }
      </section>

      <section class="peek-panel">
        <div class="peek-panel-title">🗞️ Tin hôm nay</div>
        <div class="peek-ticker-view">
          <div class="peek-ticker-track">
            {
              railTodayPosts.map(post => {
                const source = getPostSource(post);
                return (
                  <a
                    class="peek-prow"
                    href={getPostUrl(post.id, post.filePath, locale)}
                  >
                    <img
                      class="peek-prow-logo"
                      src={sourceLogoUrl(source)}
                      alt={source.name}
                    />
                    <div>
                      <div class="peek-prow-title">{post.data.title}</div>
                      <div class="peek-prow-sub">
                        {source.name} · {formatPostDate(post.data.pubDatetime)}
                      </div>
                    </div>
                  </a>
                );
              })
            }
            {
              railTodayPosts.map(post => {
                const source = getPostSource(post);
                return (
                  <a
                    class="peek-prow"
                    href={getPostUrl(post.id, post.filePath, locale)}
                  >
                    <img
                      class="peek-prow-logo"
                      src={sourceLogoUrl(source)}
                      alt={source.name}
                    />
                    <div>
                      <div class="peek-prow-title">{post.data.title}</div>
                      <div class="peek-prow-sub">
                        {source.name} · {formatPostDate(post.data.pubDatetime)}
                      </div>
                    </div>
                  </a>
                );
              })
            }
          </div>
        </div>
      </section>
    </aside>
  </div>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
