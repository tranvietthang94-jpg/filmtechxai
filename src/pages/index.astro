---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

// Sample data sources for sidebar
const sources = [
  { name: "The Verge", domain: "theverge.com", type: "press" },
  { name: "TechCrunch", domain: "techcrunch.com", type: "press" },
  { name: "Ars Technica", domain: "arstechnica.com", type: "press" },
  { name: "Engadget", domain: "engadget.com", type: "press" },
  { name: "MacRumors", domain: "macrumors.com", type: "press" },
  { name: "Tom's Hardware", domain: "tomshardware.com", type: "press" },
  { name: "MKBHD", domain: "youtube.com/@mkbhd", type: "youtube" },
  { name: "Linus Tech Tips", domain: "youtube.com/@LinusTechTips", type: "youtube" },
  { name: "Dave2D", domain: "youtube.com/@Dave2D", type: "youtube" },
  { name: "Mrwhosetheboss", domain: "youtube.com/@Mrwhosetheboss", type: "youtube" },
];

const pressCount = sources.filter(s => s.type === "press").length;
const youtubeCount = sources.filter(s => s.type === "youtube").length;
---

<Layout>
  <Header />

  <!-- peek.vn 3-column layout -->
  <div class="peek-layout">
    <!-- Left Sidebar -->
    <aside class="peek-sidebar">
      <nav>
        <a href={homePath} class="peek-nav-item active">
          <span>🏠</span> Trang chủ
        </a>
        <a href={getRelativeLocaleUrl(locale, "posts")} class="peek-nav-item">
          <span>🕐</span> {t.nav.posts}
        </a>
        <a href={getRelativeLocaleUrl(locale, "tags")} class="peek-nav-item">
          <span>🏷️</span> {t.nav.tags}
        </a>
        <a href={getRelativeLocaleUrl(locale, "about")} class="peek-nav-item">
          <span>ℹ️</span> {t.nav.about}
        </a>
      </nav>

      <div class="peek-side-title">
        <span>LỌC NGUỒN</span>
      </div>
      <nav>
        <div class="peek-src-item active">
          <span>◎</span>
          <span style="flex: 1;">Tất cả nguồn</span>
        </div>
        <div class="peek-src-item">
          <span>📰</span>
          <span style="flex: 1;">Báo chí</span>
          <span class="peek-src-badge">{pressCount}</span>
        </div>
        <div class="peek-src-item">
          <span>▶</span>
          <span style="flex: 1;">YouTube</span>
          <span class="peek-src-badge">{youtubeCount}</span>
        </div>
      </nav>

      <div class="peek-side-title">
        <span>THEO DÕI</span>
        <span>{sources.length}+</span>
      </div>
      <nav>
        {sources.map(source => (
          <div class="peek-follow-row">
            <img
              class={`peek-follow-avatar ${source.type === "youtube" ? "peek-follow-channel" : "peek-follow-logo"}`}
              src={`https://www.google.com/s2/favicons?domain=${source.domain}&sz=64`}
              alt={source.name}
            />
            {source.type === "youtube" && <span class="peek-follow-yt">▶</span>}
            {source.name}
          </div>
        ))}
        <div class="peek-follow-etc">…và hơn 20 nguồn uy tín khác</div>
      </nav>
    </aside>

    <!-- Main Feed -->
    <main id="main-content" class="peek-feed">
      <!-- Hero Section -->
      <section id="hero" class="peek-hero">
        <span class="peek-hero-flame">🔥</span>
        <div class="peek-hero-meta">
          <span class="peek-src-type">📰</span>
          <span>filmtechxai</span>
          <span class="dot">·</span>
          <span>Tin tức AI & Film</span>
          <span class="peek-hero-hot">🔥 Nóng nhất</span>
        </div>
        <h1 class="peek-hero-title">
          filmtechxai — Liếc phát biết
        </h1>
        <p class="peek-hero-summary">
          AstroPaper là một blog theme minimal, responsive, accessible và SEO-friendly. 
          Theme này tuân theo các best practices và cung cấp accessibility out of the box.
        </p>
        <div class="peek-hero-foot">
          <span class="peek-hero-sources">
            <img class="peek-savatar peek-savatar-logo" src="https://www.google.com/s2/favicons?domain=astro.build&sz=64" alt="" />
          </span>
          <span class="peek-hero-srctext">Astro Framework</span>
          <a href={getRelativeLocaleUrl(locale, "posts")} class="peek-hero-btn">
            Xem bài viết →
          </a>
        </div>
      </section>

      <!-- Featured Posts -->
      {
        featuredPosts.length > 0 && (
          <section id="featured">
            <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
              <span>⭐</span> {t.home.featured}
            </h2>
            <ul class="flex flex-col gap-4">
              {featuredPosts.map(data => (
                <li>
                  <Card variant="h3" {...data} />
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <!-- Recent Posts -->
      {
        recentPosts.length > 0 && (
          <section id="recent-posts">
            <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
              <span>🕐</span> {t.home.recentPosts}
            </h2>
            <ul class="flex flex-col gap-4">
              {recentPosts.slice(0, postsConfig.perIndex).map(data => (
                <li>
                  <Card variant="h3" {...data} />
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <!-- View All Posts -->
      <div class="text-center my-8">
        <LinkButton
          href={getRelativeLocaleUrl(locale, "posts")}
          class="peek-hero-btn inline-block"
        >
          {t.home.allPosts} →
        </LinkButton>
      </div>

      <div class="feed-sentinel"></div>
    </main>

    <!-- Right Rail -->
    <aside class="peek-rail">
      <section class="peek-panel">
        <div class="peek-panel-title">
          🔥 Tin nóng
          <span class="peek-panel-live">
            <span class="peek-live-dot"></span> LIVE
          </span>
        </div>
        {recentPosts.slice(0, 5).map(post => (
          <div class="peek-prow">
            <img
              class="peek-prow-logo"
              src={`https://www.google.com/s2/favicons?domain=astro.build&sz=64`}
              alt=""
            />
            <div>
              <div class="peek-prow-title">{post.data.title}</div>
              <div class="peek-prow-sub">
                {post.data.pubDatetime?.toLocaleDateString(locale)}
              </div>
            </div>
          </div>
        ))}
      </section>

      <section class="peek-panel">
        <div class="peek-panel-title">🗞️ Tin hôm nay</div>
        <div class="peek-ticker-view">
          <div class="peek-ticker-track">
            {recentPosts.slice(0, 4).map(post => (
              <div class="peek-prow">
                <img
                  class="peek-prow-logo"
                  src={`https://www.google.com/s2/favicons?domain=astro.build&sz=64`}
                  alt=""
                />
                <div>
                  <div class="peek-prow-title">{post.data.title}</div>
                  <div class="peek-prow-sub">
                    {post.data.pubDatetime?.toLocaleDateString(locale)}
                  </div>
                </div>
              </div>
            ))}
            <!-- Duplicate for infinite scroll effect -->
            {recentPosts.slice(0, 4).map(post => (
              <div class="peek-prow">
                <img
                  class="peek-prow-logo"
                  src={`https://www.google.com/s2/favicons?domain=astro.build&sz=64`}
                  alt=""
                />
                <div>
                  <div class="peek-prow-title">{post.data.title}</div>
                  <div class="peek-prow-sub">
                    {post.data.pubDatetime?.toLocaleDateString(locale)}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </aside>
  </div>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>